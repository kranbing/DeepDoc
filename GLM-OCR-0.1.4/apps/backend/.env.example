# 复制为 .env 后按需修改

HOST=0.0.0.0
PORT=8000

# SQLite 任务库
DATABASE_URL=sqlite+aiosqlite:///./tasks.db

# 任务输出目录（相对 backend 工作目录）
OUTPUT_DIR=./data

# 版面+OCR 流水线地址：须为 glmocr.server 的 /glmocr/parse（见主 README glmocr[server]）
# 默认 http://127.0.0.1:5002/glmocr/parse
LAYOUT_OCR_URL=http://127.0.0.1:5002/glmocr/parse
